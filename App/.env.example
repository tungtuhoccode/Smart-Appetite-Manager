# LLM Provider Configuration - see docs/llm-setup.md for free options
LLM_SERVICE_API_KEY=your-api-key
LLM_SERVICE_ENDPOINT=https://api.cerebras.ai/v1
LLM_SERVICE_PLANNING_MODEL_NAME=openai/gpt-oss-120b
LLM_SERVICE_GENERAL_MODEL_NAME=openai/gpt-oss-120b
LLM_SERVICE_IMAGE_MODEL_NAME=openai/gpt-oss-120b  # vision model for receipt scanning (must support image input)

# SAM Dev Mode - uses in-memory broker
SPOONACULAR_API_KEY=your-api-key        # used by recipe tools (App/src/recipe_agent/mealdb_tools.py)

### App settings
INVENTORY_MANAGER_DB_NAME=inventory.db   # used by inventory agent (App/configs/agents/inventory-manager.yaml)
FLIPP_POSTAL_CODE=K1A 0A6               # postal/zip code for local flyer deals (default: Ottawa)
FLIPP_LOCALE=en-us                       # locale for Flipp search (en-us or en-ca)

### SAM Config
SOLACE_DEV_MODE=true
